<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shopkart</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Poppins", sans-serif;
        }

        body {
            background: #f6f6f6;
        }

        /* NAVBAR */
        nav {
            background: #111;
            padding: 15px 40px;
            color: #fff;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        nav h1 {
            font-size: 28px;
        }

        .nav-logo {
            height: 40px; /* Adjust as needed */
            width: auto;
        }

        nav button {
            background: #ff6600;
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            color: #fff;
            font-size: 16px;
        }

        /* LOGIN MODAL */
        .login-modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
        }

        .login-modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-container {
            background: #fff;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 400px;
        }

        .login-container h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #111;
            font-size: 28px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #333;
            font-weight: 600;
        }

        .form-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 16px;
            transition: 0.3s;
        }

        .form-group input:focus {
            outline: none;
            border-color: #ff6600;
            box-shadow: 0 0 5px rgba(255, 102, 0, 0.3);
        }

        .login-btn {
            width: 100%;
            padding: 12px;
            background: #ff6600;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
            transition: 0.3s;
        }

        .login-btn:hover {
            background: #e55a00;
        }

        .signup-link {
            text-align: center;
            margin-top: 15px;
            color: #666;
            font-size: 14px;
        }

        .signup-link a {
            color: #ff6600;
            text-decoration: none;
            cursor: pointer;
            font-weight: 600;
        }

        .close-login {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .close-login:hover {
            color: #111;
        }

        .form-message {
            text-align: center;
            margin-bottom: 15px;
            padding: 10px;
            border-radius: 6px;
            display: none;
        }

        .form-message.success {
            background: #d4edda;
            color: #155724;
            display: block;
        }

        .form-message.error {
            background: #f8d7da;
            color: #721c24;
            display: block;
        }

        /* HERO BANNER */
        .hero {
            height: 55vh;
            background: url('https://images.unsplash.com/photo-1542291026-7eec264c27ff?fm=jpg&q=60&w=3000&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D') center/cover no-repeat;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            color: white;
            text-shadow: 2px 2px 8px black;
        }

        .hero h2 {
            font-size: 60px;
            font-weight: bold;
        }

        .hero p {
            font-size: 22px;
            margin-top: 8px;
        }

        /* SEARCH BAR */
        .search-container {
            display: flex;
            justify-content: center;
            margin: 25px;
        }

        .search-container input {
            width: 400px;
            padding: 12px 18px;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 16px;
        }

        /* FILTER SECTION */
        .filter-section {
            padding: 20px 30px;
            background: #fff;
            border-bottom: 1px solid #eee;
            display: flex;
            gap: 20px;
            align-items: center;
            flex-wrap: wrap;
        }

        .filter-group {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .filter-group label {
            font-weight: 600;
            color: #111;
        }

        .filter-group select {
            padding: 8px 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 14px;
            cursor: pointer;
            background: #fff;
            transition: 0.3s;
        }

        .filter-group select:hover {
            border-color: #ff6600;
        }

        .filter-group select:focus {
            outline: none;
            border-color: #ff6600;
            box-shadow: 0 0 5px rgba(255, 102, 0, 0.3);
        }

        .reset-filter {
            padding: 8px 15px;
            background: #f0f0f0;
            border: 1px solid #ddd;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.3s;
        }

        .reset-filter:hover {
            background: #ff6600;
            color: #fff;
            border-color: #ff6600;
        }

        /* PRODUCTS */
        .products {
            padding: 30px;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 25px;
        }

        .product {
            background: #fff;
            padding: 12px;
            border-radius: 10px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
            transition: .3s;
        }
        .product:hover {
            transform: scale(1.05);
        }

        .product img {
            width: 100%;
            height: 230px;
            object-fit: cover;
            border-radius: 10px;
        }

        .product button {
            width: 48%;
            padding: 10px;
            margin-top: 10px;
            background: #111;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            display: inline-block;
            margin-right: 2%;
        }

        .product button:last-child {
            margin-right: 0;
        }

        .product .buy-btn {
            background: #ff6600;
        }

        .product .buy-btn:hover {
            background: #e55a00;
        }

        .product button:hover {
            opacity: 0.9;
        }

        /* CART SIDEBAR */
        .cart {
            position: fixed;
            right: -350px;
            top: 0;
            width: 350px;
            height: 100vh;
            background: #fff;
            padding: 20px;
            box-shadow: -3px 0 8px rgba(0,0,0,0.3);
            transition: 0.4s ease;
            z-index: 20;
        }

        .cart.active {
            right: 0;
        }

        .cart-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid #ddd;
        }

        .cart-item img {
            width: 60px;
            height: 60px;
            border-radius: 6px;
            object-fit: cover;
        }

        .controls {
            display: flex;
            gap: 6px;
            margin-top: 5px;
        }

        .controls button {
            padding: 5px 10px;
            border: none;
            background: #222;
            color: white;
            border-radius: 5px;
            cursor: pointer;
        }

        .remove-btn {
            background: red;
        }

        .checkout {
            margin-top: 20px;
            width: 100%;
            background: #ff6600;
            color: white;
            padding: 10px;
            border-radius: 8px;
            border: none;
        }
        .back-btn {
    background: #111;
    color: white;
    border: none;
    padding: 8px 15px;
    border-radius: 6px;
    margin-bottom: 15px;
    cursor: pointer;
    font-size: 15px;
}
.back-btn:hover {
    background: #333;
}

        /* FOOTER */
        footer {
            background: #111;
            color: #fff;
            padding: 40px 20px;
            margin-top: 60px;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }

        .footer-section h3 {
            font-size: 18px;
            margin-bottom: 15px;
            color: #ff6600;
        }

        .footer-section ul {
            list-style: none;
        }

        .footer-section ul li {
            margin-bottom: 10px;
        }

        .footer-section ul li a {
            color: #ccc;
            text-decoration: none;
            transition: 0.3s;
        }

        .footer-section ul li a:hover {
            color: #ff6600;
        }

        .footer-section p {
            color: #ccc;
            line-height: 1.6;
            font-size: 14px;
        }

        .social-icons {
            display: flex;
            gap: 15px;
            margin-top: 15px;
        }

        .social-icons a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background: #ff6600;
            border-radius: 50%;
            color: #fff;
            text-decoration: none;
            transition: 0.3s;
            font-size: 18px;
        }

        .social-icons a:hover {
            background: #e55a00;
            transform: translateY(-3px);
        }

        .footer-bottom {
            border-top: 1px solid #333;
            margin-top: 30px;
            padding-top: 20px;
            text-align: center;
            color: #999;
            font-size: 14px;
        }

        .footer-bottom p {
            margin: 0;
        }

        /* ADDRESS MODAL */
        .address-modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
        }

        .address-modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .address-container {
            background: #fff;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 500px;
        }

        .address-container h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #111;
            font-size: 28px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #333;
            font-weight: 600;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 16px;
            transition: 0.3s;
            font-family: "Poppins", sans-serif;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #ff6600;
            box-shadow: 0 0 5px rgba(255, 102, 0, 0.3);
        }

        .address-btn {
            width: 100%;
            padding: 12px;
            background: #ff6600;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
            transition: 0.3s;
        }

        .address-btn:hover {
            background: #e55a00;
        }

        .close-address {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .close-address:hover {
            color: #111;
        }

        /* ORDER DETAILS SECTION */
        .order-details {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            border: 1px solid #eee;
        }

        .order-details h4 {
            color: #ff6600;
            margin-top: 0;
            margin-bottom: 10px;
            font-size: 16px;
        }

        .order-details p {
            margin: 5px 0;
            font-size: 14px;
            color: #555;
            line-height: 1.5;
        }

        .edit-address-btn {
            margin-top: 10px;
            padding: 8px 15px;
            background: #ff6600;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            transition: 0.3s;
        }

        .edit-address-btn:hover {
            background: #e55a00;
        }

        .remove-address-btn {
            margin-top: 10px;
            margin-left: 8px;
            padding: 8px 15px;
            background: #dc3545;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            transition: 0.3s;
        }

        .remove-address-btn:hover {
            background: #c82333;
        }

        /* PAYMENT MODAL */
        .payment-modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
        }

        .payment-modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .payment-container {
            background: #fff;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 500px;
        }

        .payment-container h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #111;
            font-size: 28px;
        }

        .payment-options {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-bottom: 20px;
        }

        .payment-option {
            display: flex;
            align-items: center;
            padding: 15px;
            border: 2px solid #ddd;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
            background: #f9f9f9;
        }

        .payment-option:hover {
            border-color: #ff6600;
            background: #fff9f5;
        }

        .payment-option input[type="radio"] {
            margin-right: 15px;
            cursor: pointer;
            width: 18px;
            height: 18px;
        }

        .payment-option-content {
            flex: 1;
        }

        .payment-option-content h4 {
            margin: 0 0 5px 0;
            color: #111;
        }

        .payment-option-content p {
            margin: 0;
            font-size: 13px;
            color: #666;
        }

        .payment-icon {
            font-size: 28px;
            margin-left: 15px;
        }

        .payment-option input[type="radio"]:checked + .payment-option-content {
            color: #ff6600;
        }

        .payment-btn {
            width: 100%;
            padding: 12px;
            background: #ff6600;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .payment-btn:hover {
            background: #e55a00;
        }

        .close-payment {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .close-payment:hover {
            color: #111;
        }

        /* CARD DETAILS MODAL */
        .card-details-modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
        }

        .card-details-modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card-details-container {
            background: #fff;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 500px;
        }

        .card-details-container h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #111;
            font-size: 28px;
        }

        .card-preview {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 25px;
            font-family: 'Courier New', monospace;
        }

        .card-preview .card-number {
            font-size: 24px;
            letter-spacing: 2px;
            margin: 15px 0;
        }

        .card-preview .card-holder {
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 15px;
        }

        .card-preview .card-expiry {
            font-size: 14px;
            margin-top: 10px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .form-row.full {
            grid-template-columns: 1fr;
        }

        .close-card-details {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .close-card-details:hover {
            color: #111;
        }

    </style>
</head>
<body>

    <!-- NAV -->
    <nav>
        <h1 style="margin: 0; font-size: 28px; color: #ff6600;">🛍️ Shopkart</h1>
        <div style="display: flex; gap: 10px;">
            <button onclick="openLoginModal()" style="background: #111; border: 1px solid #ff6600;">🔐 Login</button>
            <button onclick="toggleCart()">🛒 Cart (<span id='cart-count'>0</span>)</button>
        </div>
    </nav>

    <!-- HERO BANNER -->
    <section class="hero">
        <h2>Shopkart</h2>
        <p>Your Favorite Online Store</p>
    </section>

    <!-- SEARCH -->
    <div class="search-container">
        <input type="text" id="search" placeholder="Search products..." onkeyup="applyFilters()">
    </div>

    <!-- FILTER SECTION -->
    <div class="filter-section">
        <div class="filter-group">
            <label for="categoryFilter">Category:</label>
            <select id="categoryFilter" onchange="applyFilters()">
                <option value="">All Categories</option>
                <option value="Electronics">Electronics</option>
                <option value="Fashion">Fashion</option>
                <option value="Accessories">Accessories</option>
            </select>
        </div>

        <div class="filter-group">
            <label for="priceFilter">Price Range:</label>
            <select id="priceFilter" onchange="applyFilters()">
                <option value="">All Prices</option>
                <option value="0-20">$0 - $20</option>
                <option value="20-50">$20 - $50</option>
                <option value="50-100">$50 - $100</option>
                <option value="100-">$100+</option>
            </select>
        </div>

        <button class="reset-filter" onclick="resetFilters()">Reset Filters</button>
    </div>

    <!-- PRODUCTS -->
    <section class="products">
        <div class="product-grid" id="product-list"></div>
    </section>

    <!-- LOGIN MODAL -->
    <div class="login-modal" id="loginModal">
        <div class="login-container">
            <span class="close-login" onclick="closeLoginModal()">&times;</span>
            <h2>Login</h2>
            <div class="form-message" id="loginMessage"></div>
            <form onsubmit="handleLogin(event)">
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" required placeholder="Enter your email">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" required placeholder="Enter your password">
                </div>
                <button type="submit" class="login-btn">Login</button>
            </form>
            <div class="signup-link">
                Don't have an account? <a onclick="openSignupModal()">Sign Up</a>
            </div>
        </div>
    </div>

    <!-- SIGNUP MODAL -->
    <div class="login-modal" id="signupModal">
        <div class="login-container">
            <span class="close-login" onclick="closeSignupModal()">&times;</span>
            <h2>Sign Up</h2>
            <div class="form-message" id="signupMessage"></div>
            <form onsubmit="handleSignup(event)">
                <div class="form-group">
                    <label for="signup-name">Full Name</label>
                    <input type="text" id="signup-name" required placeholder="Enter your full name">
                </div>
                <div class="form-group">
                    <label for="signup-email">Email Address</label>
                    <input type="email" id="signup-email" required placeholder="Enter your email">
                </div>
                <div class="form-group">
                    <label for="signup-password">Password</label>
                    <input type="password" id="signup-password" required placeholder="Create a password">
                </div>
                <button type="submit" class="login-btn">Sign Up</button>
            </form>
            <div class="signup-link">
                Already have an account? <a onclick="openLoginModal()">Login</a>
            </div>
        </div>
    </div>

    <!-- CART -->
    <div class="cart" id="cart">
    <button class="back-btn" onclick="toggleCart()">⬅ Back</button>
    <h2>Your Cart</h2>

        <!-- ORDER DETAILS -->
        <div class="order-details" id="orderDetails">
            <h4>📦 Delivery Address</h4>
            <p id="addressDisplay">No address saved. Click "Buy Now" to add address.</p>
            <button class="edit-address-btn" onclick="openAddressModal()">Edit Address</button>
            <button class="remove-address-btn" onclick="removeAddress()">Remove</button>
            
            <h4 style="margin-top: 15px;">💳 Payment Method</h4>
            <p id="paymentDisplay">No payment method selected.</p>
            <button class="edit-address-btn" onclick="openPaymentModal()">Change Payment</button>
            <button class="remove-address-btn" onclick="removePaymentMethod()">Remove</button>
        </div>

        <div id="cart-items"></div>
        <h3>Total: $<span id="total">0</span></h3>
        <button class="checkout">Checkout</button>
    </div>

    <!-- ADDRESS MODAL -->
    <div class="address-modal" id="addressModal">
        <div class="address-container">
            <span class="close-address" onclick="closeAddressModal()">&times;</span>
            <h2>Delivery Address</h2>
            <form onsubmit="saveAddress(event)">
                <div class="form-group">
                    <label for="fullname">Full Name</label>
                    <input type="text" id="fullname" required placeholder="Enter your full name">
                </div>
                <div class="form-group">
                    <label for="phone">Phone Number</label>
                    <input type="tel" id="phone" required placeholder="Enter your phone number">
                </div>
                <div class="form-group">
                    <label for="street">Street Address</label>
                    <input type="text" id="street" required placeholder="Enter street address">
                </div>
                <div class="form-group">
                    <label for="city">City</label>
                    <input type="text" id="city" required placeholder="Enter city">
                </div>
                <div class="form-group">
                    <label for="state">State/Province</label>
                    <input type="text" id="state" required placeholder="Enter state">
                </div>
                <div class="form-group">
                    <label for="zip">Zip/Postal Code</label>
                    <input type="text" id="zip" required placeholder="Enter zip code">
                </div>
                <div class="form-group">
                    <label for="country">Country</label>
                    <input type="text" id="country" required placeholder="Enter country">
                </div>
                <button type="submit" class="address-btn">Continue to Checkout</button>
            </form>
        </div>
    </div>

    <!-- PAYMENT MODAL -->
    <div class="payment-modal" id="paymentModal">
        <div class="payment-container">
            <span class="close-payment" onclick="closePaymentModal()">&times;</span>
            <h2>💳 Choose Payment Method</h2>
            <form onsubmit="processPayment(event)">
                <div class="payment-options">
                    <!-- UPI Option -->
                    <label class="payment-option">
                        <input type="radio" name="payment" value="upi" required>
                        <div class="payment-option-content">
                            <h4>UPI Payment</h4>
                            <p>Google Pay, PhonePe, Paytm, BHIM</p>
                        </div>
                        <div class="payment-icon">📱</div>
                    </label>

                    <!-- Debit Card Option -->
                    <label class="payment-option">
                        <input type="radio" name="payment" value="debit" required>
                        <div class="payment-option-content">
                            <h4>Debit Card</h4>
                            <p>Visa, Mastercard, Rupay</p>
                        </div>
                        <div class="payment-icon">💳</div>
                    </label>

                    <!-- Credit Card Option -->
                    <label class="payment-option">
                        <input type="radio" name="payment" value="credit" required>
                        <div class="payment-option-content">
                            <h4>Credit Card</h4>
                            <p>Visa, Mastercard, American Express</p>
                        </div>
                        <div class="payment-icon">🏦</div>
                    </label>
                </div>
                <button type="submit" class="payment-btn">Proceed with Payment</button>
            </form>
        </div>
    </div>

    <!-- CARD DETAILS MODAL -->
    <div class="card-details-modal" id="cardDetailsModal">
        <div class="card-details-container">
            <span class="close-card-details" onclick="closeCardDetailsModal()">&times;</span>
            <h2 id="cardTypeTitle">💳 Debit Card Details</h2>
            
            <!-- Card Preview -->
            <div class="card-preview">
                <div style="font-size: 12px; opacity: 0.8;">CARD NUMBER</div>
                <div class="card-number" id="cardPreview">•••• •••• •••• ••••</div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px;">
                    <div>
                        <div style="font-size: 11px; opacity: 0.8;">CARD HOLDER</div>
                        <div id="cardHolderPreview" style="font-size: 14px; margin-top: 5px;">YOUR NAME</div>
                    </div>
                    <div style="text-align: right;">
                        <div style="font-size: 11px; opacity: 0.8;">EXPIRES</div>
                        <div id="cardExpiryPreview" style="font-size: 14px; margin-top: 5px;">MM/YY</div>
                    </div>
                </div>
            </div>

            <form onsubmit="saveCardDetails(event)">
                <div class="form-group full">
                    <label for="cardHolderName">Card Holder Name</label>
                    <input type="text" id="cardHolderName" required placeholder="Enter name as shown on card" oninput="updateCardPreview()">
                </div>

                <div class="form-group full">
                    <label for="cardNumber">Card Number</label>
                    <input type="text" id="cardNumber" required placeholder="1234 5678 9012 3456" maxlength="19" oninput="formatCardNumber(this)">
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="cardExpiry">Expiry Date (MM/YY)</label>
                        <input type="text" id="cardExpiry" required placeholder="MM/YY" maxlength="5" oninput="formatExpiry(this)">
                    </div>
                    <div class="form-group">
                        <label for="cardCVV">CVV/CVC</label>
                        <input type="text" id="cardCVV" required placeholder="123" maxlength="4" inputmode="numeric">
                    </div>
                </div>

                <div class="form-group full" style="margin-top: 25px;">
                    <button type="submit" class="payment-btn">Complete Payment</button>
                </div>
            </form>
        </div>
    </div>

    <!-- FOOTER -->
    <footer>
        <div class="footer-container">
            <div class="footer-section">
                <h3>About Shopkart</h3>
                <p>Shopkart is your ultimate destination for quality products at unbeatable prices. We provide a seamless shopping experience with fast delivery and excellent customer service.</p>
                <div class="social-icons">
                    <a href="#" title="Facebook">f</a>
                    <a href="#" title="Twitter">𝕏</a>
                    <a href="#" title="Instagram">📷</a>
                    <a href="#" title="LinkedIn">in</a>
                </div>
            </div>

            <div class="footer-section">
                <h3>Quick Links</h3>
                <ul>
                    <li><a href="#home">Home</a></li>
                    <li><a href="#shop">Shop</a></li>
                    <li><a href="#about">About Us</a></li>
                    <li><a href="#contact">Contact</a></li>
                    <li><a href="#faq">FAQ</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h3>Customer Support</h3>
                <ul>
                    <li><a href="#shipping">Shipping Info</a></li>
                    <li><a href="#returns">Returns & Exchanges</a></li>
                    <li><a href="#warranty">Warranty</a></li>
                    <li><a href="#privacy">Privacy Policy</a></li>
                    <li><a href="#terms">Terms & Conditions</a></li>
                </ul>
            </div>

            <div class="footer-section">
                <h3>Contact Us</h3>
                <p><strong>Email:</strong> support@shophub.com</p>
                <p><strong>Phone:</strong> +1 (800) 123-4567</p>
                <p><strong>Address:</strong> 123 Commerce Street, Shopping City, SC 12345</p>
                <p><strong>Hours:</strong> Mon-Fri: 9AM-6PM EST</p>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; 2025 Shopkart. All Rights Reserved. | Designed with ❤️ for you</p>
        </div>
    </footer>

    <script>
        // LOGIN & SIGNUP FUNCTIONS
        function openLoginModal() {
            closeSignupModal();
            document.getElementById("loginModal").classList.add("active");
        }

        function closeLoginModal() {
            document.getElementById("loginModal").classList.remove("active");
        }

        function openSignupModal() {
            closeLoginModal();
            document.getElementById("signupModal").classList.add("active");
        }

        function closeSignupModal() {
            document.getElementById("signupModal").classList.remove("active");
        }

        function handleLogin(event) {
            event.preventDefault();
            
            const email = document.getElementById("email").value;
            const password = document.getElementById("password").value;
            const messageDiv = document.getElementById("loginMessage");
            
            // Get registered users from localStorage
            const users = JSON.parse(localStorage.getItem("users")) || [];
            
            // Check if user exists
            const user = users.find(u => u.email === email && u.password === password);
            
            if (user) {
                messageDiv.className = "form-message success";
                messageDiv.innerText = "✓ Login successful! Welcome back!";
                localStorage.setItem("currentUser", JSON.stringify(user));
                
                setTimeout(() => {
                    closeLoginModal();
                    document.getElementById("email").value = "";
                    document.getElementById("password").value = "";
                    messageDiv.className = "form-message";
                }, 1500);
            } else {
                messageDiv.className = "form-message error";
                messageDiv.innerText = "✗ Invalid email or password!";
            }
        }

        function handleSignup(event) {
            event.preventDefault();
            
            const name = document.getElementById("signup-name").value;
            const email = document.getElementById("signup-email").value;
            const password = document.getElementById("signup-password").value;
            const messageDiv = document.getElementById("signupMessage");
            
            // Get existing users from localStorage
            let users = JSON.parse(localStorage.getItem("users")) || [];
            
            // Check if email already exists
            if (users.find(u => u.email === email)) {
                messageDiv.className = "form-message error";
                messageDiv.innerText = "✗ Email already registered!";
                return;
            }
            
            // Add new user
            const newUser = { id: users.length + 1, name, email, password };
            users.push(newUser);
            localStorage.setItem("users", JSON.stringify(users));
            localStorage.setItem("currentUser", JSON.stringify(newUser));
            
            messageDiv.className = "form-message success";
            messageDiv.innerText = "✓ Account created successfully!";
            
            setTimeout(() => {
                closeSignupModal();
                document.getElementById("signup-name").value = "";
                document.getElementById("signup-email").value = "";
                document.getElementById("signup-password").value = "";
                messageDiv.className = "form-message";
            }, 1500);
        }

        const products = [
        
          { id: 1, name: "Smart Watch", price: 59, img: "https://images.samsung.com/is/image/samsung/p6pim/in/f2507/gallery/in-galaxy-watch8-l330-sm-l330nzsains-thumb-547660161" },
            { id: 2, name: "Shoes", price: 79, img: "https://assets.myntassets.com/w_412,q_30,dpr_3,fl_progressive,f_webp/assets/images/2025/JUNE/17/XdVforSW_cfacd00a9a9c44c3a810862f0990453d.jpg" },
            { id: 3, name: "Headphones", price: 49, img: "https://media.istockphoto.com/id/1185081321/photo/black-bluetooth-headphone-isolated-on-white-background-with-clipping-path-image-closeup.jpg?s=612x612&w=0&k=20&c=N4ytMnu-tdiu5MKwiCy4ODRaP5PVEkN9TdxJy-74yFk=" },
            { id: 4, name: "Backpack", price: 39, img: "https://m.media-amazon.com/images/I/31BFu0elHGL._SR290,290_.jpg" },
             {id:5, name:"Sunglasses", price:29, img:"data:image/jpeg;base64,", category:"Fashion", desc:"Classic UV-protective shades."},
            {id:6, name:"Portable Speaker", price:45, img:"https://m.media-amazon.com/images/I/21ehUBpWZML._SR290,290_.jpg", category:"Electronics", desc:"Water-resistant speaker with punchy bass."},
            {id:7, name:"Beanie Hat", price:18, img:"data:image/jpeg;base64,", category:"Fashion", desc:"Cozy beanie for chilly days."},
            {id:8, name:"Travel Mug", price:22, img:"data:image/jpeg;base64,", category:"Accessories", desc:"Keeps drinks hot for hours."}
            
         
          
    
        ];
        



        let cart = [];

        const productList = document.getElementById("product-list");

        function loadProducts() {
            productList.innerHTML = "";
            products.forEach(p => {
                productList.innerHTML += `
                    <div class="product">
                        <img src="${p.img}">
                        <h3>${p.name}</h3>
                        <p>$${p.price}</p>
                        <button onclick="addToCart(${p.id})">Add to Cart</button>
                        <button class="buy-btn" onclick="buyNow(${p.id})">Buy Now</button>
                    </div>
                `;
            });
        }

        loadProducts();
        updateCart();
        displayAddressDetails();

        function addToCart(id) {
            const item = cart.find(p => p.id === id);

            if (item) {
                item.qty++;
            } else {
                const product = products.find(p => p.id === id);
                cart.push({ ...product, qty: 1 });
            }

            updateCart();
        }

        function buyNow(id) {
            const item = cart.find(p => p.id === id);

            if (item) {
                item.qty++;
            } else {
                const product = products.find(p => p.id === id);
                cart.push({ ...product, qty: 1 });
            }

            updateCart();
            // Always show address form (pre-filled with saved data if exists)
            openAddressModal();
        }

        function updateCart() {
            document.getElementById("cart-count").innerText = cart.length;

            let total = 0;
            let html = "";

            cart.forEach((c, index) => {
                total += c.price * c.qty;

                html += `
                    <div class="cart-item">
                        <img src="${c.img}">
                        <div style="flex:1;">
                            <strong>${c.name}</strong><br>
                            $${c.price} × ${c.qty}
                            <div class="controls">
                                <button onclick="changeQty(${index}, 1)">+</button>
                                <button onclick="changeQty(${index}, -1)">-</button>
                                <button class="remove-btn" onclick="removeItem(${index})">Remove</button>
                            </div>
                        </div>
                    </div>
                `;
            });

            document.getElementById("cart-items").innerHTML = html;
            document.getElementById("total").innerText = total;
            displayAddressDetails();
        }

        function changeQty(index, amount) {
            cart[index].qty += amount;

            if (cart[index].qty <= 0) {
                cart.splice(index, 1);
            }

            updateCart();
        }

        function removeItem(index) {
            cart.splice(index, 1);
            updateCart();
        }

        function toggleCart() {
            document.getElementById("cart").classList.toggle("active");
            displayAddressDetails();
        }

        function displayAddressDetails() {
            const savedAddress = JSON.parse(sessionStorage.getItem("userAddress"));
            const addressDisplay = document.getElementById("addressDisplay");
            const paymentData = JSON.parse(localStorage.getItem("paymentMethod"));
            const paymentDisplay = document.getElementById("paymentDisplay");
            
            if (savedAddress && savedAddress.fullname) {
                addressDisplay.innerHTML = `
                    <strong>${savedAddress.fullname}</strong><br>
                    📱 ${savedAddress.phone}<br>
                    📍 ${savedAddress.street}<br>
                    ${savedAddress.city}, ${savedAddress.state} ${savedAddress.zip}<br>
                    🌍 ${savedAddress.country}
                `;
            } else {
                addressDisplay.innerHTML = "No address saved. Click \"Edit Address\" to add one.";
            }
            
            if (paymentData && paymentData.display) {
                paymentDisplay.innerHTML = `<strong>${paymentData.display}</strong>`;
            } else {
                paymentDisplay.innerHTML = "No payment method selected.";
            }
        }

        // ADDRESS MODAL FUNCTIONS
        function openAddressModal() {
            // Load saved address from sessionStorage if exists
            const savedAddress = JSON.parse(sessionStorage.getItem("userAddress")) || {};
            document.getElementById("fullname").value = savedAddress.fullname || "";
            document.getElementById("phone").value = savedAddress.phone || "";
            document.getElementById("street").value = savedAddress.street || "";
            document.getElementById("city").value = savedAddress.city || "";
            document.getElementById("state").value = savedAddress.state || "";
            document.getElementById("zip").value = savedAddress.zip || "";
            document.getElementById("country").value = savedAddress.country || "";
            
            document.getElementById("addressModal").classList.add("active");
        }

        function closeAddressModal() {
            document.getElementById("addressModal").classList.remove("active");
        }

        function saveAddress(event) {
            event.preventDefault();
            
            const address = {
                fullname: document.getElementById("fullname").value,
                phone: document.getElementById("phone").value,
                street: document.getElementById("street").value,
                city: document.getElementById("city").value,
                state: document.getElementById("state").value,
                zip: document.getElementById("zip").value,
                country: document.getElementById("country").value
            };
            
            // Save address to sessionStorage (clears on page refresh)
            sessionStorage.setItem("userAddress", JSON.stringify(address));
            
            // Close address modal and show payment modal
            closeAddressModal();
            openPaymentModal();
        }

        function removeAddress() {
            if (confirm("Are you sure you want to remove the saved delivery address?")) {
                sessionStorage.removeItem("userAddress");
                displayAddressDetails();
                alert("✓ Delivery address removed successfully!");
            }
        }

        // PAYMENT MODAL FUNCTIONS
        function openPaymentModal() {
            document.getElementById("paymentModal").classList.add("active");
        }

        function closePaymentModal() {
            document.getElementById("paymentModal").classList.remove("active");
        }

        function processPayment(event) {
            event.preventDefault();
            
            const paymentMethod = document.querySelector('input[name="payment"]:checked').value;
            const paymentMethods = {
                'upi': '📱 UPI Payment',
                'debit': '💳 Debit Card',
                'credit': '🏦 Credit Card'
            };
            
            // If card payment, open card details modal
            if (paymentMethod === 'debit' || paymentMethod === 'credit') {
                closePaymentModal();
                openCardDetailsModal(paymentMethod);
                return;
            }
            
            // For UPI, proceed directly
            localStorage.setItem("paymentMethod", JSON.stringify({
                method: paymentMethod,
                display: paymentMethods[paymentMethod],
                timestamp: new Date().toLocaleString()
            }));
            
            alert(`✅ Payment method selected: ${paymentMethods[paymentMethod]}\n\nProceeding to UPI gateway...`);
            closePaymentModal();
            toggleCart();
        }

        // CARD DETAILS FUNCTIONS
        function openCardDetailsModal(cardType) {
            const title = cardType === 'debit' ? '💳 Debit Card Details' : '🏦 Credit Card Details';
            document.getElementById("cardTypeTitle").innerText = title;
            
            // Load saved card details from sessionStorage if exists
            const savedCard = JSON.parse(sessionStorage.getItem("cardDetails")) || {};
            document.getElementById("cardHolderName").value = savedCard.holder || "";
            document.getElementById("cardNumber").value = savedCard.number || "";
            document.getElementById("cardExpiry").value = savedCard.expiry || "";
            document.getElementById("cardCVV").value = savedCard.cvv || "";
            
            // Store card type
            document.getElementById("cardDetailsModal").dataset.cardType = cardType;
            
            document.getElementById("cardDetailsModal").classList.add("active");
        }

        function closeCardDetailsModal() {
            document.getElementById("cardDetailsModal").classList.remove("active");
        }

        function formatCardNumber(input) {
            let value = input.value.replace(/\s/g, '');
            let formattedValue = '';
            for (let i = 0; i < value.length; i++) {
                if (i > 0 && i % 4 === 0) {
                    formattedValue += ' ';
                }
                formattedValue += value[i];
            }
            input.value = formattedValue;
            updateCardPreview();
        }

        function formatExpiry(input) {
            let value = input.value.replace(/\D/g, '');
            if (value.length >= 2) {
                value = value.slice(0, 2) + '/' + value.slice(2, 4);
            }
            input.value = value;
            updateCardPreview();
        }

        function updateCardPreview() {
            const cardNumber = document.getElementById("cardNumber").value.replace(/\s/g, '');
            const lastFour = cardNumber.slice(-4);
            const masked = '•••• •••• •••• ' + (lastFour || '••••');
            document.getElementById("cardPreview").innerText = masked;
            
            const holder = document.getElementById("cardHolderName").value || 'YOUR NAME';
            document.getElementById("cardHolderPreview").innerText = holder.toUpperCase();
            
            const expiry = document.getElementById("cardExpiry").value || 'MM/YY';
            document.getElementById("cardExpiryPreview").innerText = expiry;
        }

        function saveCardDetails(event) {
            event.preventDefault();
            
            const cardType = document.getElementById("cardDetailsModal").dataset.cardType;
            const paymentMethods = {
                'debit': '💳 Debit Card',
                'credit': '🏦 Credit Card'
            };
            
            const cardDetails = {
                type: cardType,
                holder: document.getElementById("cardHolderName").value,
                number: document.getElementById("cardNumber").value,
                expiry: document.getElementById("cardExpiry").value,
                cvv: document.getElementById("cardCVV").value,
                lastFour: document.getElementById("cardNumber").value.slice(-4)
            };
            
            // Save card details to sessionStorage (clears on page refresh)
            sessionStorage.setItem("cardDetails", JSON.stringify(cardDetails));
            localStorage.setItem("paymentMethod", JSON.stringify({
                method: cardType,
                display: paymentMethods[cardType] + ' •••• ' + cardDetails.lastFour,
                timestamp: new Date().toLocaleString()
            }));
            
            alert(`✅ Card details saved!\n\n${paymentMethods[cardType]}\nCard ending in ${cardDetails.lastFour}\n\nProceeding to payment...`);
            
            closeCardDetailsModal();
            toggleCart();
        }

        function removePaymentMethod() {
            if (confirm("Are you sure you want to remove the saved payment method?")) {
                localStorage.removeItem("paymentMethod");
                sessionStorage.removeItem("cardDetails");
                displayAddressDetails();
                alert("✓ Payment method removed successfully!");
            }
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const loginModal = document.getElementById("loginModal");
            const signupModal = document.getElementById("signupModal");
            const addressModal = document.getElementById("addressModal");
            
            if (event.target === loginModal) {
                closeLoginModal();
            }
            if (event.target === signupModal) {
                closeSignupModal();
            }
            if (event.target === addressModal) {
                closeAddressModal();
            }
            if (event.target === document.getElementById("paymentModal")) {
                closePaymentModal();
            }
            if (event.target === document.getElementById("cardDetailsModal")) {
                closeCardDetailsModal();
            }
        }

        /* SEARCH FUNCTION */
        function searchProduct() {
            let val = document.getElementById("search").value.toLowerCase();

            productList.innerHTML = "";

            products
                .filter(p => p.name.toLowerCase().includes(val))
                .forEach(p => {
                    productList.innerHTML += `
                        <div class="product">
                            <img src="${p.img}">
                            <h3>${p.name}</h3>
                            <p>$${p.price}</p>
                            <button onclick="addToCart(${p.id})">Add to Cart</button>
                            <button class="buy-btn" onclick="buyNow(${p.id})">Buy Now</button>
                        </div>
                    `;
                });
        }
    </script>

</body>
</html>
